# Provider: "groq" (default) or "nvidia" — both OpenAI-compatible.
LLM_PROVIDER=groq

# Groq
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# NVIDIA NIM (used when LLM_PROVIDER=nvidia). Use a strong model.
NVIDIA_API_KEY=your_nvidia_key_here
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# Port (Render injects PORT automatically)
PORT=8787

# CORS — your Vercel URL + localhost (comma-separated), or * to allow all.
ALLOWED_ORIGINS=http://localhost:3000
